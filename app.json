{
  "expo": {
    "name": "Vigil",
    "slug": "vigil-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vigil",
    "backgroundColor": "#0B0F19",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blandcreative.vigil"
    },
    "android": {
      "package": "com.blandcreative.vigil",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F19",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Vigil uses the camera to scan product barcodes so you can track prices instantly."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1107314c-2b69-4071-a1a6-9b1cc2c66354"
      }
    },
    "owner": "creativetwo"
  }
}
